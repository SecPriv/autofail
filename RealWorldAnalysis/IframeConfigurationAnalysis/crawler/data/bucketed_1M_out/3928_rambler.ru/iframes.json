        "srcdoc": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n  <head><base href=\"https://cdn.dsp-rambler.ru/imp/642116574/\"/>\r\n    <meta charset=\"UTF-8\" />\r\n    <title>Banner</title>\r\n    <link\r\n      href=\"https://static.rambler.ru/fonts/Manrope/Manrope.css\"\r\n      rel=\"stylesheet\"\r\n    />\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\r\n    <style>\r\n      /* Для увеличения специфичности все стили оборачиваем в #banner-360x250 */\r\n      #banner-360x250 .floating-widget {\r\n        position: absolute;\r\n        bottom: 20px;\r\n        right: 20px;\r\n        font-size: 15px;\r\n        font-weight: 500;\r\n        line-height: 20px;\r\n      }\r\n\r\n      /* скрытый чекбокс */\r\n      #banner-360x250 .toggle-checkbox {\r\n        display: none;\r\n      }\r\n\r\n      /* кнопка */\r\n      #banner-360x250 .floating-button {\r\n        width: 25px;\r\n        height: 25px;\r\n        background-color: #343b4c;\r\n        border-radius: 5px;\r\n        cursor: pointer;\r\n        display: -webkit-box;\r\n        display: -ms-flexbox;\r\n        display: flex;\r\n        -webkit-box-align: center;\r\n        -ms-flex-align: center;\r\n        align-items: center;\r\n        -webkit-box-pack: center;\r\n        -ms-flex-pack: center;\r\n        justify-content: center;\r\n        -webkit-transition: opacity 0.2s ease;\r\n        -o-transition: opacity 0.2s ease;\r\n        transition: opacity 0.2s ease;\r\n        opacity: 0.4;\r\n      }\r\n\r\n      #banner-360x250 .floating-button:hover {\r\n        opacity: 1;\r\n      }\r\n\r\n      /* иконки */\r\n      #banner-360x250 .icon {\r\n        color: #fff;\r\n        line-height: 1;\r\n        opacity: 0;\r\n        position: absolute;\r\n        inset: 0;\r\n        display: -webkit-box;\r\n        display: -ms-flexbox;\r\n        display: flex;\r\n        -webkit-box-pack: center;\r\n        -ms-flex-pack: center;\r\n        justify-content: center;\r\n        -webkit-box-align: center;\r\n        -ms-flex-align: center;\r\n        align-items: center;\r\n        -webkit-transition: opacity 0.2s ease, -webkit-transform 0.2s ease;\r\n        transition: opacity 0.2s ease, -webkit-transform 0.2s ease;\r\n        -o-transition: opacity 0.2s ease, transform 0.2s ease;\r\n        transition: opacity 0.2s ease, transform 0.2s ease;\r\n        transition: opacity 0.2s ease, transform 0.2s ease,\r\n          -webkit-transform 0.2s ease;\r\n      }\r\n\r\n      #banner-360x250 .toggle-checkbox:checked + .floating-button {\r\n        opacity: 1;\r\n      }\r\n\r\n      #banner-360x250\r\n        .toggle-checkbox:not(:checked)\r\n        + .floating-button\r\n        .icon-closed {\r\n        opacity: 1;\r\n      }\r\n\r\n      #banner-360x250 .toggle-checkbox:checked + .floating-button .icon-opened {\r\n        opacity: 1;\r\n      }\r\n\r\n      /* панель */\r\n      #banner-360x250 .floating-panel {\r\n        font-family: Manrope Variable, Manrope, sans-serif;\r\n        text-align: left;\r\n        position: absolute;\r\n        background-color: #343b4c;\r\n        color: #fff;\r\n        padding: 10px;\r\n        border-radius: 5px;\r\n        overflow-y: scroll;\r\n        max-height: 170px;\r\n        opacity: 0;\r\n        -webkit-transform: translateY(5px);\r\n        -ms-transform: translateY(5px);\r\n        transform: translateY(5px);\r\n        pointer-events: none;\r\n        -webkit-transition: opacity 0.2s ease, -webkit-transform 0.2s ease;\r\n        transition: opacity 0.2s ease, -webkit-transform 0.2s ease;\r\n        -o-transition: opacity 0.2s ease, transform 0.2s ease;\r\n        transition: opacity 0.2s ease, transform 0.2s ease;\r\n        transition: opacity 0.2s ease, transform 0.2s ease,\r\n          -webkit-transform 0.2s ease;\r\n        bottom: 35px;\r\n        right: 0;\r\n        width: 320px;\r\n        -webkit-box-sizing: border-box;\r\n        box-sizing: border-box;\r\n        -webkit-box-